---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Terms of Service | Still">
  <Header />
  
  <main class="pt-32 min-h-screen flex flex-col">
    <section class="py-24 bg-surface flex-grow">
      <div class="max-w-4xl mx-auto px-6">
        <h1 class="text-5xl font-display text-primary leading-tight mb-8">Terms of Service</h1>
        <p class="text-on-surface-variant">The Terms of Service content will be updated here.</p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
