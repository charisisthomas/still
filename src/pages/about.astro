---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<Layout title="About | Still">
  <Header />
  
  <main class="pt-32">
    <!-- Hero Section: The Narrative -->
    <section class="px-6 md:px-12 max-w-[1440px] mx-auto mb-32">
        <div class="grid md:grid-cols-12 gap-12 items-end">
            <div class="md:col-span-7 animate-on-scroll">
                <span class="font-label text-sm uppercase tracking-[0.3em] text-secondary mb-6 block">Our Narrative</span>
                <h1 class="font-headline text-5xl md:text-7xl leading-[1.1] mb-12 text-on-surface" style="text-wrap: balance;">
                    The Artisans <br/>
                    <span class="italic font-normal text-primary">Behind the Screen</span>
                </h1>
                <p class="font-body text-xl md:text-2xl text-secondary leading-relaxed max-w-2xl" style="text-wrap: pretty;">
                    We believe that your digital presence should feel as intentional and timeless as a hand-pressed wedding invitation. Our mission is to craft digital love stories that transcend trends, focusing on the poetry of the moment.
                </p>
            </div>
            <div class="md:col-span-5 relative animate-on-scroll" style="transition-delay: 200ms;">
                <div class="aspect-[4/5] bg-surface-container-low overflow-hidden rounded-sm border border-outline-variant/10 shadow-xl">
                    <img class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105" data-alt="Minimalist desk setup with high-end editorial magazines, a brass letter opener, and soft morning sunlight casting elegant shadows" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDnRZU7nFqDksImJJIQNiqrkqIXhWnKRPrFKX9GSBt8WWwpd66GKeSWfOSMaiidu8R9UbQ2aztabDaEibDnrxBV-b3QmCcMa8vmvk8ll_rj2PxD0YmJYvX4Ldw2LbDqAYkgXGNb0rT_Cu-IALmVqzcS8CJ6clMdUqeZq1Fj3pqJ5nKvzbK-MTqf5SmCq4znx4Ua1SutEo-oAwCxsrhOi6vNwTOcCOaZAJfVCyz17FfZxz1W-fLhHtDuIcTiJ4VhwsC4ujDTJ6siAuDH"/>
                </div>
                <div class="absolute -bottom-8 -left-8 bg-surface p-8 max-w-[280px] hidden md:block rounded-sm shadow-md border border-outline-variant/5">
                    <p class="font-headline italic text-lg text-primary">"Every pixel is an opportunity for grace."</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Our Process -->
    <section class="bg-surface-container-low py-32 px-6 md:px-12 border-y border-outline-variant/10">
        <div class="max-w-[1440px] mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-start mb-24 animate-on-scroll">
                <h2 class="font-headline text-4xl md:text-5xl mb-8 md:mb-0 text-on-surface">A Curated <span class="italic text-primary">Process</span></h2>
                <p class="font-body text-secondary max-w-md text-lg leading-relaxed">Our methodology is rooted in the fine art tradition: meticulous preparation, thoughtful execution, and a refined finish.</p>
            </div>
            <div class="grid md:grid-cols-4 gap-0 divide-y md:divide-y-0 md:divide-x divide-outline-variant/20 border border-outline-variant/20 rounded-sm overflow-hidden bg-surface-container-lowest shadow-sm">
                <!-- Step 1 -->
                <div class="group p-8 md:p-12 hover:bg-surface transition-colors duration-500 animate-on-scroll">
                    <span class="font-headline italic text-4xl text-primary-fixed-dim block mb-8 transition-transform group-hover:-translate-y-1">01</span>
                    <h3 class="font-label text-sm uppercase tracking-widest mb-4 font-semibold text-on-surface">Consultation</h3>
                    <p class="font-body text-sm text-secondary leading-relaxed">A deep dive into your vision, aesthetic preferences, and the unique nuances of your story.</p>
                    <div class="mt-8 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">chat_bubble</span>
                    </div>
                </div>
                <!-- Step 2 -->
                <div class="group p-8 md:p-12 hover:bg-surface transition-colors duration-500 animate-on-scroll" style="transition-delay: 100ms;">
                    <span class="font-headline italic text-4xl text-primary-fixed-dim block mb-8 transition-transform group-hover:-translate-y-1">02</span>
                    <h3 class="font-label text-sm uppercase tracking-widest mb-4 font-semibold text-on-surface">Design</h3>
                    <p class="font-body text-sm text-secondary leading-relaxed">Translating your essence into a visual language of typography, texture, and tailored layouts.</p>
                    <div class="mt-8 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">edit_document</span>
                    </div>
                </div>
                <!-- Step 3 -->
                <div class="group p-8 md:p-12 hover:bg-surface transition-colors duration-500 animate-on-scroll" style="transition-delay: 200ms;">
                    <span class="font-headline italic text-4xl text-primary-fixed-dim block mb-8 transition-transform group-hover:-translate-y-1">03</span>
                    <h3 class="font-label text-sm uppercase tracking-widest mb-4 font-semibold text-on-surface">Development</h3>
                    <p class="font-body text-sm text-secondary leading-relaxed">Bespoke engineering that prioritizes performance and seamless interaction on every device.</p>
                    <div class="mt-8 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">code</span>
                    </div>
                </div>
                <!-- Step 4 -->
                <div class="group p-8 md:p-12 hover:bg-surface transition-colors duration-500 animate-on-scroll" style="transition-delay: 300ms;">
                    <span class="font-headline italic text-4xl text-primary-fixed-dim block mb-8 transition-transform group-hover:-translate-y-1">04</span>
                    <h3 class="font-label text-sm uppercase tracking-widest mb-4 font-semibold text-on-surface">Launch</h3>
                    <p class="font-body text-sm text-secondary leading-relaxed">The grand reveal. A polished digital home ready to welcome your guests and showcase your legacy.</p>
                    <div class="mt-8 opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Philosophy: Bento Grid -->
    <section class="py-32 px-6 md:px-12 max-w-[1440px] mx-auto">
        <div class="grid md:grid-cols-12 gap-6 md:gap-8">
            <!-- Large Image Block -->
            <div class="md:col-span-8 relative group overflow-hidden rounded-sm shadow-sm animate-on-scroll">
                <img class="w-full h-[600px] object-cover transition-transform duration-1000 group-hover:scale-105" data-alt="Interior of a luxury design studio with marble tables, gold accents, and a large floor-to-ceiling window with soft architectural lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAmVNhgGULIHaxLFV8dmCA7CoI_dfgHpd_i072l74vljadGTyykv3tw6hux9H4-ZRcLGVUs7bkjC7Cp5xR77YXlaPwtgGhomkVgy23zDGIjvTYFD-Kqn4zse32SdjHTQr8MoySTCTrosdvFiGpeT2nwkEBFa6EpFUOE_MOOF8mPwMN3lWfxpNcViN3MTPNEJHd4fnJR2MZann1pvPXfz6LxXPckLjHLoYa5edzBhtDbwueMvipQgBSFmFCjwT03nTCcqkaixMegdqw0"/>
                <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 to-transparent opacity-80"></div>
                <div class="absolute bottom-12 left-12">
                    <h2 class="font-headline text-surface-container-lowest text-4xl italic">Our Design Values</h2>
                </div>
            </div>
            
            <!-- Text Block: Detail -->
            <div class="md:col-span-4 bg-tertiary-container p-12 flex flex-col justify-center rounded-sm shadow-sm animate-on-scroll" style="transition-delay: 150ms;">
                <h3 class="font-headline text-2xl mb-6 text-on-tertiary-container">Unwavering Detail</h3>
                <p class="font-body text-on-tertiary-container/80 leading-relaxed text-lg">
                    We obsess over the kerning of a headline and the ease of a scroll. In the luxury digital space, the smallest details are the loudest.
                </p>
            </div>
            
            <!-- Text Block: Sophistication -->
            <div class="md:col-span-4 bg-surface-container-highest p-12 flex flex-col justify-center rounded-sm shadow-sm animate-on-scroll" style="transition-delay: 300ms;">
                <h3 class="font-headline text-2xl mb-6 text-on-surface">Modern Sophistication</h3>
                <p class="font-body text-secondary leading-relaxed text-lg">
                    Avoiding the clutter of traditional templates. We seek architectural balance and quiet confidence in every composition.
                </p>
            </div>
            
            <!-- Small Image Block -->
            <div class="md:col-span-8 overflow-hidden rounded-sm shadow-sm animate-on-scroll group" style="transition-delay: 450ms;">
                <img class="w-full h-[400px] object-cover transition-transform duration-1000 group-hover:scale-105" data-alt="Close up of artisan paper being hand-embossed with a bespoke monogram, soft focus, tactile texture, neutral tones" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB3kCzZ0_u9XFNFs0EU0Fuab4FK30oVN-QoRpoZs7Qm9_-1YRxgvd5O-k5soE-3rzTPlnXMfYyqXP7dMiZYCFsQhHud-dWqj4mwCMxeZTveEsE1erhV_OdEbNsMl_Cv40fvcRELR4su8VnavcdQP82oQUeZioZYItEV8wDEtzCAF9qGpCI-RTPfXcBjctLrFpDLamneoDM1wutwLtCF6gzHowdeCLcZPNecwd_FGzAt4i4LzNwfP6asbYNfFQbvj_NGuBPvtDfMiMre"/>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-6 md:px-12 bg-surface-container-low border-t border-outline-variant/10">
        <div class="max-w-[800px] mx-auto text-center animate-on-scroll">
            <h2 class="font-headline text-4xl md:text-6xl mb-12 text-on-surface">Let's Create Something <span class="italic text-primary">Beautiful</span> Together</h2>
            <div class="flex justify-center">
                <Button href="/contact" variant="primary" class="px-12 py-4">Get in Touch</Button>
            </div>
        </div>
    </section>
  </main>
  
  <Footer />
</Layout>
