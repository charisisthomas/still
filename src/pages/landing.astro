---
import Layout from '../layouts/Layout.astro';
import caseStudiesData from '../data/extracted_case_studies.json';

const getHiResImage = (slug, fallback) => {
  const caseData = caseStudiesData.find(c => c.slug === slug);
  return (caseData && caseData.images && caseData.images[0]) ? caseData.images[0] : `/assets/${fallback}`;
};
---

<Layout title="Bespoke Digital Wedding Studio | Still">
  
  <!-- TopNavBar (Internal Anchor Links Only for CRO) -->
  <header class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md transition-all duration-300 border-b border-outline-variant/10">
    <div class="flex justify-between items-center px-6 md:px-8 py-6 w-full max-w-[1440px] mx-auto">
      <a class="text-xl font-headline tracking-widest text-primary font-bold uppercase" href="#">Still</a>
      <nav class="hidden md:flex items-center gap-10">
        <a class="text-[11px] font-label uppercase tracking-widest text-primary border-b border-primary pb-1 hover:text-primary transition-colors duration-300" href="#portfolio">Portfolio</a>
        <a class="text-[11px] font-label uppercase tracking-widest text-secondary hover:text-primary transition-colors duration-300" href="#process">Process</a>
        <a class="text-[11px] font-label uppercase tracking-widest text-secondary hover:text-primary transition-colors duration-300" href="#faq">FAQ</a>
        <a class="text-[11px] font-label uppercase tracking-widest text-secondary hover:text-primary transition-colors duration-300" href="#contact">Contact</a>
      </nav>
      <button class="md:hidden text-primary">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">menu</span>
      </button>
    </div>
  </header>

  <main class="mt-24 bg-background">
    
    <!-- Hero Section -->
    <section class="relative w-full min-h-[60vh] flex items-center justify-center py-24 overflow-hidden border-b border-outline-variant/20">
      <div class="absolute inset-0 z-0">
        <video autoplay loop muted playsinline poster="/images/Close-up_cinematic_shot_in_slow-motion_202605202128.jpeg" class="w-full h-full object-cover">
          <source src="/images/Woman_scrolling_glass_tablet_202605202134.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-surface/70 backdrop-blur-[2px]"></div>
      </div>
      <div class="relative z-10 text-center max-w-4xl mx-auto px-6 md:px-8 space-y-8 animate-on-scroll">
        <span class="font-label text-[11px] text-surface uppercase tracking-[0.2em] font-bold bg-on-surface px-5 py-2 rounded-full inline-block shadow-lg">Bespoke Digital Wedding Studio</span>
        <h1 class="font-headline text-5xl md:text-[72px] text-on-surface leading-[1.1]" style="text-wrap: balance;">
            Elevate Your Celebration <br/>
            <span class="text-primary italic">Beyond The Page</span>
        </h1>
        <p class="font-body text-lg text-secondary max-w-2xl mx-auto leading-[1.7]">
            We build performant, one-of-one digital ecosystems for destination weddings. From elegant editorial layouts to a frictionless concierge app, we ensure your digital legacy matches the prestige of your event.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 pt-4 justify-center">
            <a class="bg-primary text-on-primary font-label text-[13px] uppercase tracking-[0.2em] font-bold px-8 py-4 text-center hover:opacity-90 transition-opacity shadow-lg" href="#contact">
                SECURE YOUR DATES
            </a>
            <a class="bg-surface/90 backdrop-blur-md border border-outline-variant/50 text-on-surface font-label text-[13px] uppercase tracking-[0.2em] font-bold px-8 py-4 text-center hover:bg-surface transition-all shadow-md" href="#portfolio">
                EXPLORE COMMISSIONS
            </a>
        </div>
      </div>
    </section>

    <!-- Why Still Section (The Standard) -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-8 py-24 md:py-[120px]">
      <div class="text-center mb-16 max-w-3xl mx-auto animate-on-scroll">
        <span class="font-label text-[11px] text-primary uppercase tracking-[0.28em] font-semibold">The Standard</span>
        <h2 class="font-headline text-4xl md:text-[48px] text-on-surface mt-4">Architecting Digital Intimacy</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="space-y-6 p-8 border border-outline-variant/20 bg-surface-container-lowest rounded-[2px] shadow-sm hover:shadow-md transition-shadow animate-on-scroll">
            <div class="aspect-[4/3] w-full overflow-hidden rounded-[2px] bg-surface-container-low mb-6 border border-outline-variant/10">
                <img src="/images/invitation-indian-mobile.jpg" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" alt="Bespoke Design Layouts" />
            </div>
            <span class="font-headline text-[64px] text-primary-fixed-dim/40 italic block leading-none">01</span>
            <h3 class="font-headline text-2xl text-on-surface">Zero Templates</h3>
            <p class="font-body text-[15px] text-secondary leading-[1.7]">Every platform begins as a blank canvas. We coordinate color systems from your floral design layouts and craft layout typography to match your physical stationery suites perfectly.</p>
        </div>
        <div class="space-y-6 p-8 border border-outline-variant/20 bg-surface-container-lowest rounded-[2px] shadow-sm hover:shadow-md transition-shadow animate-on-scroll" style="transition-delay: 100ms;">
            <div class="aspect-[4/3] w-full overflow-hidden rounded-[2px] bg-surface-container-low mb-6 border border-outline-variant/10">
                <img src="/images/wedding-guest-list-digital.png" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" alt="Mobile Concierge App" />
            </div>
            <span class="font-headline text-[64px] text-primary-fixed-dim/40 italic block leading-none">02</span>
            <h3 class="font-headline text-2xl text-on-surface">The Mobile Concierge</h3>
            <p class="font-body text-[15px] text-secondary leading-[1.7]">Frictionless on-the-ground execution. Real-time flight tracking, dynamic multi-event itinerary toggles, and beautifully styled interactive maps keeping guests synced without apps.</p>
        </div>
        <div class="space-y-6 p-8 border border-outline-variant/20 bg-surface-container-lowest rounded-[2px] shadow-sm hover:shadow-md transition-shadow animate-on-scroll" style="transition-delay: 200ms;">
            <div class="aspect-[4/3] w-full overflow-hidden rounded-[2px] bg-[#9bb0b8] mb-6 border border-outline-variant/10 flex items-center justify-center p-4">
                <div class="w-48 h-[340px] bg-surface rounded-[2rem] border-[6px] border-surface-container relative overflow-hidden flex flex-col transform scale-[0.85] origin-center shadow-lg">
                    <div class="p-4 pt-8 text-center">
                        <span class="material-symbols-outlined text-primary mb-3" style="font-variation-settings: 'FILL' 1;">favorite</span>
                        <h4 class="font-headline text-lg mb-4 text-on-surface">Will You Join Us?</h4>
                        <div class="space-y-2">
                            <button class="w-full p-2 border border-[#9bb0b8] bg-[#9bb0b8]/5 text-[10px] text-left flex justify-between items-center text-on-surface rounded-sm cursor-pointer">
                                <span>Accept with Joy</span>
                                <div class="w-1.5 h-1.5 rounded-full bg-[#9bb0b8]"></div>
                            </button>
                            <button class="w-full p-2 border border-outline-variant/30 text-[10px] text-left flex justify-between items-center opacity-60 text-on-surface rounded-sm cursor-pointer">
                                <span>Decline with Regret</span>
                            </button>
                        </div>
                    </div>
                    <button class="absolute bottom-6 left-1/2 -translate-x-1/2 w-4/5 bg-[#9bb0b8] text-white py-2 rounded-full text-[10px] font-bold tracking-widest shadow-md hover:bg-primary transition-colors">SUBMIT</button>
                </div>
            </div>
            <span class="font-headline text-[64px] text-primary-fixed-dim/40 italic block leading-none">03</span>
            <h3 class="font-headline text-2xl text-on-surface">Sustainable Luxury</h3>
            <p class="font-body text-[15px] text-secondary leading-[1.7]">Our Paperless Portal manages complex conditional invitation logistics, multi-language adaptations, and digital menus seamlessly to reduce print footprints while amplifying prestige.</p>
        </div>
      </div>
    </section>

    <!-- The Process Section -->
    <section class="bg-on-surface text-surface py-24 md:py-[120px]" id="process">
      <div class="max-w-[1440px] mx-auto px-6 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="animate-on-scroll">
            <span class="font-label text-[11px] text-primary-fixed-dim uppercase tracking-[0.28em] font-semibold">Methodology</span>
            <h2 class="font-headline text-4xl md:text-[48px] mt-4 leading-[1.1]" style="text-wrap: balance;">From Vision to Live Stream</h2>
            <p class="mt-6 text-surface-dim font-body text-lg max-w-md leading-[1.7]">Our process is as curated as our designs. We move with intentionality, ensuring your story is told with the gravity it deserves.</p>
          </div>
          <div class="space-y-12">
            <div class="flex items-start gap-8 group animate-on-scroll">
                <div class="w-12 h-12 flex-shrink-0 border border-outline-variant/30 flex items-center justify-center font-headline italic text-xl group-hover:bg-primary-fixed-dim group-hover:text-on-surface group-hover:border-primary-fixed-dim transition-colors rounded-[2px]">1</div>
                <div>
                    <h4 class="font-label text-[11px] uppercase tracking-[0.2em] mb-2 font-bold text-surface">Editorial Consultation</h4>
                    <p class="text-surface-dim font-body text-[15px] leading-[1.7]">We begin with a deep dive into your wedding aesthetic, physical stationery samples, and guest logistics to build a unique visual DNA.</p>
                </div>
            </div>
            <div class="flex items-start gap-8 group animate-on-scroll" style="transition-delay: 100ms;">
                <div class="w-12 h-12 flex-shrink-0 border border-outline-variant/30 flex items-center justify-center font-headline italic text-xl group-hover:bg-primary-fixed-dim group-hover:text-on-surface group-hover:border-primary-fixed-dim transition-colors rounded-[2px]">2</div>
                <div>
                    <h4 class="font-label text-[11px] uppercase tracking-[0.2em] mb-2 font-bold text-surface">Design &amp; Development</h4>
                    <p class="text-surface-dim font-body text-[15px] leading-[1.7]">Our studio builds your custom platform, refining typography and interactive elements until the digital experience mirrors the event's prestige.</p>
                </div>
            </div>
            <div class="flex items-start gap-8 group animate-on-scroll" style="transition-delay: 200ms;">
                <div class="w-12 h-12 flex-shrink-0 border border-outline-variant/30 flex items-center justify-center font-headline italic text-xl group-hover:bg-primary-fixed-dim group-hover:text-on-surface group-hover:border-primary-fixed-dim transition-colors rounded-[2px]">3</div>
                <div>
                    <h4 class="font-label text-[11px] uppercase tracking-[0.2em] mb-2 font-bold text-surface">Concierge Launch</h4>
                    <p class="text-surface-dim font-body text-[15px] leading-[1.7]">Invitations are deployed via our secure portal. As the date nears, your mobile concierge goes live, guiding guests through their journey.</p>
                </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Global Portfolio Section -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-8 py-24 md:py-[120px]" id="portfolio">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 border-b border-outline-variant/20 pb-8 animate-on-scroll">
        <div>
            <span class="font-label text-[11px] text-primary uppercase tracking-[0.28em] font-semibold">Proof of Craft</span>
            <h2 class="font-headline text-4xl md:text-[48px] text-on-surface mt-4">Singular Digital Commissions</h2>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Project 1 -->
        <div class="group cursor-pointer animate-on-scroll">
            <div class="overflow-hidden bg-surface-container-low rounded-[2px]">
                <img alt="Amalfi Grandeur" class="w-full aspect-[3/4] object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out" src={getHiResImage('the-amalfi-grandeur', 'The_Amalfi_Grandeur.png')} />
            </div>
            <div class="mt-6">
                <h4 class="font-headline text-2xl text-on-surface group-hover:text-primary transition-colors">The Amalfi Grandeur</h4>
                <p class="font-label text-[10px] uppercase tracking-[0.2em] text-secondary mt-2">Julia &amp; Robert — Amalfi Coast, Italy</p>
            </div>
        </div>
        <!-- Project 2 -->
        <div class="group cursor-pointer lg:mt-16 animate-on-scroll" style="transition-delay: 100ms;">
            <div class="overflow-hidden bg-surface-container-low rounded-[2px]">
                <img alt="Santorini Serenity" class="w-full aspect-[3/4] object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out" src={getHiResImage('the-santorini-serenity', 'The_Santorini_Serenity.png')} />
            </div>
            <div class="mt-6">
                <h4 class="font-headline text-2xl text-on-surface group-hover:text-primary transition-colors">The Santorini Serenity</h4>
                <p class="font-label text-[10px] uppercase tracking-[0.2em] text-secondary mt-2">Mei &amp; Kenji — Santorini, Greece</p>
            </div>
        </div>
        <!-- Project 3 -->
        <div class="group cursor-pointer animate-on-scroll" style="transition-delay: 200ms;">
            <div class="overflow-hidden bg-surface-container-low rounded-[2px]">
                <img alt="Stockholm Summer" class="w-full aspect-[3/4] object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out" src={getHiResImage('the-stockholm-summer', 'The_Stockholm_Summer.png')} />
            </div>
            <div class="mt-6">
                <h4 class="font-headline text-2xl text-on-surface group-hover:text-primary transition-colors">The Stockholm Summer</h4>
                <p class="font-label text-[10px] uppercase tracking-[0.2em] text-secondary mt-2">Astrid &amp; Nils — Stockholm, Sweden</p>
            </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="bg-surface-container-low py-24 md:py-[120px] border-y border-outline-variant/10" id="faq">
      <div class="max-w-[1440px] mx-auto px-6 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4 animate-on-scroll">
            <span class="font-label text-[11px] text-primary uppercase tracking-[0.28em] font-semibold">Clarity</span>
            <h2 class="font-headline text-4xl text-on-surface mt-4 leading-tight">Transparent Realities</h2>
            <p class="font-body text-[16px] text-secondary mt-6 leading-[1.7]">Navigating the nuances of digital commissions for once-in-a-lifetime events.</p>
        </div>
        <div class="lg:col-span-8 space-y-4 animate-on-scroll" style="transition-delay: 200ms;">
            <!-- FAQ Item 1 -->
            <details class="bg-surface border border-outline-variant/20 rounded-[2px] shadow-sm hover:shadow-md transition-shadow group overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex justify-between items-center p-6 lg:p-8 cursor-pointer list-none outline-none">
                    <h4 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors pr-8">How do older guests interact with a digital layout?</h4>
                    <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                </summary>
                <div class="px-6 lg:px-8 pb-8 font-body text-[15px] leading-[1.7] text-secondary border-t border-outline-variant/10 pt-6">
                    Frictionless accessibility is our baseline standard. Platforms function via simple, direct text links. No app store installation, profile creations, or password setups are demanded from users. If they can open an email, they can use your platform.
                </div>
            </details>
            <!-- FAQ Item 2 -->
            <details class="bg-surface border border-outline-variant/20 rounded-[2px] shadow-sm hover:shadow-md transition-shadow group overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex justify-between items-center p-6 lg:p-8 cursor-pointer list-none outline-none">
                    <h4 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors pr-8">How are bespoke project investments calculated?</h4>
                    <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                </summary>
                <div class="px-6 lg:px-8 pb-8 font-body text-[15px] leading-[1.7] text-secondary border-t border-outline-variant/10 pt-6">
                    Commissions are scoped individually based on parameters like localization translation counts, multi-day itinerary complexities, and interactive map requirements. Individual proposals are prepared within five working days post-call.
                </div>
            </details>
            <!-- FAQ Item 3 -->
            <details class="bg-surface border border-outline-variant/20 rounded-[2px] shadow-sm hover:shadow-md transition-shadow group overflow-hidden [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex justify-between items-center p-6 lg:p-8 cursor-pointer list-none outline-none">
                    <h4 class="font-headline text-xl text-on-surface group-hover:text-primary transition-colors pr-8">Is there a minimum timeframe required?</h4>
                    <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                </summary>
                <div class="px-6 lg:px-8 pb-8 font-body text-[15px] leading-[1.7] text-secondary border-t border-outline-variant/10 pt-6">
                    We recommend reaching out at least 6-9 months before your wedding. However, we occasionally accept expedited commissions depending on our current studio capacity and the complexity of the digital requirements.
                </div>
            </details>
        </div>
      </div>
    </section>

    <!-- Final Hook & Form -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-8 py-24 md:py-[120px]" id="contact">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="font-label text-[11px] text-primary uppercase tracking-[0.28em] font-semibold">Application</span>
        <h2 class="font-headline text-4xl md:text-[48px] text-on-surface mt-4">Begin Your Commission</h2>
        <p class="font-body text-[16px] leading-[1.7] text-secondary mt-6 max-w-xl mx-auto">
            We accept a highly limited capacity of event commissions annually to preserve execution clarity. Share your baseline logistical targets below.
        </p>
      </div>
      <div class="max-w-3xl mx-auto bg-surface-container-low p-8 lg:p-12 border border-outline-variant/20 rounded-[2px] shadow-sm animate-on-scroll transition-all duration-500" style="transition-delay: 100ms;">
        <div id="landing-form-status" class="hidden mb-6"></div>
        <form id="landing-form" class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="flex flex-col space-y-3">
                    <label class="font-label text-[11px] text-secondary uppercase tracking-[0.15em] font-bold">Your Name</label>
                    <input name="name" class="bg-transparent border-0 border-b border-outline-variant/40 focus:ring-0 focus:border-primary px-0 py-2 placeholder:text-outline-variant transition-colors font-body text-[15px] text-on-surface outline-none" placeholder="E.g. Alexandra Smith" type="text" required />
                </div>
                <div class="flex flex-col space-y-3">
                    <label class="font-label text-[11px] text-secondary uppercase tracking-[0.15em] font-bold">Email Address</label>
                    <input name="email" class="bg-transparent border-0 border-b border-outline-variant/40 focus:ring-0 focus:border-primary px-0 py-2 placeholder:text-outline-variant transition-colors font-body text-[15px] text-on-surface outline-none" placeholder="name@domain.com" type="email" required />
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="flex flex-col space-y-3">
                    <label class="font-label text-[11px] text-secondary uppercase tracking-[0.15em] font-bold">Target Celebration Date</label>
                    <input name="date" class="bg-transparent border-0 border-b border-outline-variant/40 focus:ring-0 focus:border-primary px-0 py-2 text-on-surface font-body text-[15px] transition-colors outline-none" type="date" required />
                </div>
                <div class="flex flex-col space-y-3">
                    <label class="font-label text-[11px] text-secondary uppercase tracking-[0.15em] font-bold">Event Location &amp; Venues</label>
                    <input name="location" class="bg-transparent border-0 border-b border-outline-variant/40 focus:ring-0 focus:border-primary px-0 py-2 placeholder:text-outline-variant transition-colors font-body text-[15px] text-on-surface outline-none" placeholder="E.g. Ravello, Italy" type="text" required />
                </div>
            </div>
            <div class="flex flex-col space-y-3">
                <label class="font-label text-[11px] text-secondary uppercase tracking-[0.15em] font-bold">Estimated Guest Count</label>
                <select name="guests" required class="bg-transparent border-0 border-b border-outline-variant/40 focus:ring-0 focus:border-primary px-0 py-2 text-secondary font-body text-[15px] appearance-none transition-colors outline-none cursor-pointer">
                    <option value="" disabled selected>Select an option</option>
                    <option value="Intimate (under 50)">Intimate (under 50)</option>
                    <option value="Mid-sized (50-150)">Mid-sized (50-150)</option>
                    <option value="Large scale (150+)">Large scale (150+)</option>
                </select>
            </div>
            <div class="flex flex-col space-y-3">
                <label class="font-label text-[11px] text-secondary uppercase tracking-[0.15em] font-bold">Unique Architectural Vision or Requirements</label>
                <textarea name="message" class="bg-transparent border-0 border-b border-outline-variant/40 focus:ring-0 focus:border-primary px-0 py-2 placeholder:text-outline-variant resize-none font-body text-[15px] text-on-surface transition-colors outline-none" placeholder="Tell us about multi-day event components, language needs, or planning timelines..." rows="4"></textarea>
            </div>
            <button id="landing-submit-btn" class="w-full bg-primary text-on-primary font-label text-[13px] uppercase tracking-[0.2em] font-bold px-8 py-5 hover:bg-primary/90 transition-all rounded-[2px] shadow-md mt-4 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2" type="submit">
                SUBMIT INQUIRY &amp; CHECK AVAILABILITY
            </button>
            <p class="text-[10px] text-secondary text-center uppercase tracking-[0.15em] leading-relaxed pt-2">
                By submitting, you agree to our standard information processing parameters detailed in our explicit <a class="underline hover:text-primary transition-colors" href="/privacy" target="_blank">Privacy Framework</a>.
            </p>
        </form>
      </div>

      <script>
        const landingForm = document.getElementById('landing-form');
        const landingSubmitBtn = document.getElementById('landing-submit-btn');
        const landingFormStatus = document.getElementById('landing-form-status');
        
        if (landingForm && landingSubmitBtn) {
          const fields = landingForm.querySelectorAll('input, textarea, select');
          
          landingForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (landingFormStatus) {
              landingFormStatus.innerHTML = '';
              landingFormStatus.className = 'hidden';
            }
            
            const formData = new FormData(landingForm);
            
            fields.forEach(field => field.setAttribute('disabled', 'true'));
            landingSubmitBtn.setAttribute('disabled', 'true');
            const originalBtnText = landingSubmitBtn.innerHTML;
            landingSubmitBtn.innerHTML = `
              <svg class="animate-spin h-5 w-5 text-on-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              SENDING...
            `;
            
            try {
              const data = {};
              formData.forEach((value, key) => {
                data[key] = value;
              });
              
              const response = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
              });
              
              const result = await response.json();
              
              if (response.ok && result.success) {
                const container = landingForm.parentElement;
                if (container) {
                  container.style.transition = 'opacity 0.4s ease';
                  container.style.opacity = '0';
                  setTimeout(() => {
                    container.innerHTML = `
                      <div class="text-center py-16 px-6" style="animation: fadeIn 0.5s ease forwards;">
                        <div class="w-16 h-16 bg-primary/10 border border-primary/20 rounded-full flex items-center justify-center mx-auto mb-6">
                          <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">done</span>
                        </div>
                        <h3 class="font-display text-3xl text-primary italic mb-4">Inquiry Received</h3>
                        <p class="font-body text-[15px] text-secondary leading-relaxed max-w-md mx-auto mb-8">
                          Thank you, <strong class="text-on-surface font-semibold">${data.name}</strong>. Your details have been transmitted via secure connection to our studio.
                        </p>
                        <p class="font-body text-xs text-secondary/60 max-w-sm mx-auto leading-relaxed border-t border-outline-variant/10 pt-6 uppercase tracking-wider">
                          We review all applications within 48 hours and will respond with a tailored proposal mapping to your aesthetic targets.
                        </p>
                      </div>
                    `;
                    container.style.opacity = '1';
                  }, 400);
                }
              } else {
                throw new Error(result.error || 'Something went wrong. Please try again.');
              }
            } catch (err) {
              console.error(err);
              fields.forEach(field => field.removeAttribute('disabled'));
              landingSubmitBtn.removeAttribute('disabled');
              landingSubmitBtn.innerHTML = originalBtnText;
              
              if (landingFormStatus) {
                landingFormStatus.innerHTML = `
                  <div class="flex items-center gap-3 p-4 bg-red-500/10 border border-red-500/20 text-red-800 text-sm rounded-sm">
                    <span class="material-symbols-outlined text-red-800 text-[20px]" style="font-variation-settings: 'FILL' 1;">error</span>
                    <span>${err.message || 'There was a connection issue. Please check your network and try again.'}</span>
                  </div>
                `;
                landingFormStatus.className = 'block';
                landingFormStatus.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            }
          });
        }
      </script>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-surface-container-low w-full py-20 px-6 md:px-8 border-t border-outline-variant/20">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center max-w-[1440px] mx-auto w-full">
      <div class="space-y-4 mb-8 md:mb-0">
        <span class="text-2xl font-headline font-bold text-primary tracking-widest uppercase">STILL STUDIO</span>
        <p class="font-body text-[13px] text-secondary max-w-xs leading-[1.7]">Still is an independent digital innovation initiative of <a href="https://massion.io" class="hover:underline text-primary transition-colors" target="_blank" rel="nofollow">Massion Digital</a>. All rights reserved &copy; 2026.</p>
      </div>
      <div class="grid grid-cols-2 gap-x-12 gap-y-6">
        <a class="font-label text-[11px] uppercase tracking-widest text-secondary hover:text-primary transition-colors" href="/privacy" target="_blank">Privacy</a>
        <a class="font-label text-[11px] uppercase tracking-widest text-secondary hover:text-primary transition-colors" href="/terms" target="_blank">Terms</a>
      </div>
    </div>
  </footer>
</Layout>
