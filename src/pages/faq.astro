---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<Layout title="FAQ | Still">
  <Header />
  
  <main class="w-full bg-surface pt-[84px]">
    
    <!-- Hero Section -->
    <section class="relative w-full bg-surface py-20 md:py-24 overflow-hidden border-b border-outline-variant/10">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
                <!-- Left Column (Text) -->
                <div class="md:col-span-7 flex flex-col justify-center relative z-10 animate-on-scroll">
                    <span class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-primary mb-6 block">
                        FAQ
                    </span>
                    <h1 class="font-headline text-5xl md:text-[64px] leading-[1.1] text-on-surface mb-8" style="text-wrap: balance;">
                        Questions We<br/>
                        <span class="italic text-primary">Hear Most Often</span>
                    </h1>
                    <p class="font-body text-lg text-secondary max-w-[520px] leading-[1.75] mb-8" style="text-wrap: pretty;">
                        We've collected the questions couples ask us most — before the discovery call, during the proposal stage, and occasionally at 11pm two weeks before the wedding. If your question isn't here, reach out directly. We read everything.
                    </p>
                    <div>
                        <a class="font-label text-[14px] font-semibold text-primary hover:text-primary-fixed-dim border-b border-primary pb-1 transition-colors" href="mailto:hello@still.com">
                            hello@still.com
                        </a>
                    </div>
                </div>
                
                <!-- Right Column (Decorative) -->
                <div class="hidden md:flex md:col-span-5 items-center justify-center relative pointer-events-none select-none animate-on-scroll" style="transition-delay: 200ms;">
                    <span class="font-headline italic text-[320px] lg:text-[420px] text-primary-fixed-dim opacity-[0.15] leading-none transform translate-y-[-20px]">
                        ?
                    </span>
                </div>
            </div>
        </div>
    </section>

    <!-- Sticky Category Navigation -->
    <nav class="sticky top-[84px] z-40 w-full h-[56px] bg-surface-container-low/95 backdrop-blur-md border-b border-outline-variant/20 flex items-center overflow-x-auto no-scrollbar shadow-sm">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12 w-full flex items-center space-x-8 md:space-x-[64px]">
            <a class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-primary hover:text-primary-fixed-dim transition-colors whitespace-nowrap" href="#getting-started">Getting Started</a>
            <a class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary hover:text-primary transition-colors whitespace-nowrap" href="#the-product">The Product</a>
            <a class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary hover:text-primary transition-colors whitespace-nowrap" href="#working-with-us">Working With Us</a>
            <a class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary hover:text-primary transition-colors whitespace-nowrap" href="#destination-weddings">Destination Weddings</a>
            <a class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary hover:text-primary transition-colors whitespace-nowrap" href="#sustainability">Sustainability</a>
            <a class="font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary hover:text-primary transition-colors whitespace-nowrap" href="#pricing">Pricing</a>
        </div>
    </nav>

    <!-- Section A: 01 GETTING STARTED -->
    <section id="getting-started" class="w-full bg-surface py-20 md:py-[100px] border-b border-outline-variant/10 scroll-mt-[140px]">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
                <div class="md:col-span-3 mb-8 md:mb-0 animate-on-scroll">
                    <span class="block font-headline italic text-[56px] md:text-[64px] text-primary-fixed-dim leading-none mb-2">01</span>
                    <span class="block font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary">GETTING STARTED</span>
                </div>
                <div class="md:col-span-9 animate-on-scroll" style="transition-delay: 100ms;">
                    <div class="space-y-4">
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">How far in advance should we reach out?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Twelve months before your wedding date is our ideal starting point — it gives us time to do our most considered work without pressure on either side. We regularly work with six-month timelines and occasionally shorter. The first step is always a free discovery call, so reach out as soon as you start thinking about it and we'll tell you honestly what's possible.
                            </div>
                        </details>
                        
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">Do you have availability for our date?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                We take a small number of commissions each year — by design, so that every project gets our full attention. The quickest way to check availability is to send us a brief inquiry. We respond within 48 hours, every time.
                            </div>
                        </details>
                        
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">We're not sure whether we need a website, an app, or both. Can you help us decide?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                That's exactly what the discovery call is for. Tell us about your wedding — the location, the guest count, how many people are travelling internationally, what your day actually looks like — and we'll give you an honest recommendation. No obligation, no sales pressure. Some couples genuinely only need a website. We'll tell you if that's you.
                            </div>
                        </details>
                        
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">Do you work with couples based outside the UK or Europe?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Yes. The majority of our commissions involve international couples, international guests, or both. We've built experiences for weddings across Europe, the Middle East, Asia, North America, and Australia, and we work entirely remotely. Timezone differences haven't been a barrier once.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">We've enquired with other studios who use templates. What makes Still different?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Template platforms are built around a general use case. Still is built around your specific wedding — your story, your cultural context, your guests' needs, your aesthetic. The difference shows in the details: conditional RSVP logic for different guest types, real-time flight tracking, hand-illustrated maps, editorial narrative that sounds like you rather than a press release. We're also a human team you can hold accountable from first call to final delivery.
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section B: 02 THE PRODUCT -->
    <section id="the-product" class="w-full bg-surface-container-low py-20 md:py-[100px] border-b border-outline-variant/10 scroll-mt-[140px]">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
                <div class="md:col-span-3 mb-8 md:mb-0 animate-on-scroll">
                    <span class="block font-headline italic text-[56px] md:text-[64px] text-primary-fixed-dim leading-none mb-2">02</span>
                    <span class="block font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary">THE PRODUCT</span>
                </div>
                <div class="md:col-span-9 animate-on-scroll" style="transition-delay: 100ms;">
                    <div class="space-y-4">
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">What exactly is a wedding website?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                A Still wedding website is a fully bespoke, password-protected digital space — the official home of your wedding from engagement announcement to the morning your last guest checks out. It contains your love story, RSVP management with conditional logic, travel and accommodation guides, your schedule, venue information, and anything else your guests need to know. It's designed around your aesthetic, built from a blank canvas, and exists nowhere else on the internet in quite the same form.
                            </div>
                        </details>
                        
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">What is a guest app, and does it require a download?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Our guest apps are mobile-optimised web applications — your guests access them through a link, in their browser. No download, no account creation, no app store. It works on every modern smartphone, tablet, and laptop. For couples who want a native app listed in the App Store or Google Play, that's available as an optional addition.
                            </div>
                        </details>
                        
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">What's the difference between the website and the guest app?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                The website is the pre-wedding experience — it tells your story, collects RSVPs, provides travel information, and builds anticipation. The guest app is the during-wedding experience — it provides live updates, real-time schedules, photo sharing, transport requests, and concierge features your guests can use while they're there. Most of our destination wedding clients choose both, which we call the Full Commission.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">What is the Paperless Portal?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                The Paperless Portal is our sustainability-led offering — a beautifully designed digital suite that replaces your entire printed stationery set. Digital invitations, RSVP collection, menus, programmes, seating guides, and a live itinerary, all in one platform. Zero print. As seen in Vogue and Brides. It's available as a standalone commission or as an addition to any website or Full Commission build.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">Can our site and app work in multiple languages?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Yes. We build multilingual platforms as standard for international weddings — the site or app automatically adapts to each visitor's browser language, or allows manual switching. We've built in English, French, Arabic, Swedish, Japanese, and Mandarin, among others. You provide the translated copy — we give you a structured document that makes this straightforward, and we handle all technical implementation and testing.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">How long does the site stay live after our wedding?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Your digital experience stays live for 6 months after your wedding date, included in your commission fee. After that, it moves to a low-cost archival plan, or we provide a static export as a permanent offline keepsake — whichever you prefer.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">Is our guest data secure?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Yes. Every platform we build is fully GDPR-compliant. Guest data is encrypted in transit and at rest, never shared with third parties, and deleted from our servers after your wedding unless you request otherwise in writing. Full details are in our Privacy Policy.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors pr-8">What happens to the platform after the wedding?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                It becomes an archive. Every RSVP, every guest message, every shared photograph — preserved in a single, beautifully designed digital record. We keep it live for 6 months, then offer a low-cost archival plan or a static export. Some couples revisit it every anniversary. We've had clients describe it as the best wedding gift they gave themselves.
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section C: 03 WORKING WITH US -->
    <section id="working-with-us" class="w-full bg-surface py-20 md:py-[100px] border-b border-outline-variant/10 scroll-mt-[140px]">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
                <div class="md:col-span-3 mb-8 md:mb-0 animate-on-scroll">
                    <span class="block font-headline italic text-[56px] md:text-[64px] text-primary-fixed-dim leading-none mb-2">03</span>
                    <span class="block font-label text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary">WORKING WITH US</span>
                </div>
                <div class="md:col-span-9 animate-on-scroll" style="transition-delay: 100ms;">
                    <div class="space-y-4">
                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">What does the design process look like?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Our process is iterative and collaborative. We start with discovery and mood-boarding to align on aesthetic direction, followed by wireframing the user experience. Once the structure is agreed, we move into high-fidelity design, prototyping, and finally technical development and testing.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">How much involvement is required from us?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                We respect your time. We need your focused attention at three key stages: the initial discovery call, the creative direction approval, and the final sign-off. Between those milestones, we handle the heavy lifting. We provide clear, structured requests for content and feedback to keep the momentum high.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">Can we update the site ourselves?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Yes. While we manage all technical aspects, we provide you with a simplified dashboard for essential updates — adding guest names to your list, updating shuttle times, or making small copy tweaks. For anything structural or design-related, we stay on hand to handle it for you.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">Do you handle RSVPs for us?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                We build the technical infrastructure to collect and organize your RSVPs. You'll have real-time access to the data in a clean, exportable format. If you're working with a wedding planner, we usually grant them access to manage the logistics while you enjoy watching the 'Yes' count grow.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">Who writes the copy for our site?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                We offer two approaches: we can work with the copy you provide, or you can engage our in-house editorial team to interview you and write your story in the Still house style — refined, understated, and personal.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">Will the site be mobile-friendly?</h3>
                                <span class="material-symbols-outlined text-secondary group-hover:text-primary transition-transform duration-300 group-open:rotate-45" style="font-variation-settings: 'FILL' 1;">add</span>
                            </summary>
                            <div class="mt-6 text-secondary leading-relaxed font-body border-t border-outline-variant/20 pt-6">
                                Beyond friendly. We design 'mobile-first' because that's how 90% of your guests will experience your wedding — while traveling, in their hotel room, or at the venue. Every feature is tested across all major device types.
                            </div>
                        </details>

                        <details class="bg-surface border border-outline-variant/20 p-6 rounded-sm shadow-sm hover:shadow-md transition-shadow group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex justify-between items-center list-none outline-none">
                                <h3 class="font-headline text-lg md:text-xl text-on-surface group-hover:text-primary transition-colors">How do you handle password protection?</h3>
