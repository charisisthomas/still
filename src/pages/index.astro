---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import caseStudiesData from '../data/extracted_case_studies.json';

// Helper to get hi-res image
const getHiResImage = (slug, fallback) => {
  const caseData = caseStudiesData.find(c => c.slug === slug);
  return (caseData && caseData.images && caseData.images[0]) ? caseData.images[0] : `/assets/${fallback}`;
};
---

<Layout title="Still – Bespoke Sustainable Wedding Digital Studio">
  <Header />
  
  <main class="pt-32">
    <!-- Hero Section -->
    <section class="min-h-[85vh] flex items-center relative overflow-hidden bg-surface">
      <!-- Subtle radial gradient background -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-primary-container)_0%,_transparent_50%)] opacity-20 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
        <div class="lg:col-span-7 flex flex-col justify-center animate-on-scroll">
          <span class="text-secondary text-sm tracking-widest uppercase mb-4 block">Bespoke Wedding Websites</span>
          <h1 class="text-6xl lg:text-7xl font-display text-primary leading-[1.1] mb-8">
            Digital Elegance for Your <span class="italic text-primary-dim">Special Day</span>
          </h1>
          <div class="max-w-xl">
            <p class="text-lg text-on-surface-variant leading-relaxed mb-10">
              We design and build fully bespoke digital experiences for couples around the world — seamless across desktop for meticulous planning, and functioning exactly like a native app on mobile for your guests.
            </p>
          <div class="flex flex-col sm:flex-row gap-6 mt-4">
            <!-- Swapped variants to establish hierarchy -->
            <Button href="/contact" variant="primary">Start an Inquiry</Button>
            <Button href="/portfolio" variant="secondary">See Our Work</Button>
          </div>
          </div>
        </div>
        
        <div class="lg:col-span-5 relative h-[600px] w-full rounded-sm overflow-hidden bg-surface-container-low border border-outline-variant/10 shadow-2xl shadow-primary/5">
          <img src="/assets/Wedding_Atmosphere.png" alt="Bespoke Wedding Atmosphere" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-surface-dim opacity-10"></div>
        </div>
      </div>
    </section>

    <!-- Rest of the sections remain unchanged -->
    <!-- ... -->

    <!-- Bottom CTA -->
    <section class="py-32 bg-surface">
      <div class="max-w-4xl mx-auto px-6 text-center animate-on-scroll">
        <span class="text-secondary text-sm tracking-widest uppercase mb-6 block">Limited Commissions Available for 2026 & 2027</span>
        <h2 class="text-5xl md:text-6xl font-display text-primary leading-tight mb-8">Ready to Begin?</h2>
        <p class="text-lg text-on-surface-variant leading-relaxed mb-12">We take a small number of commissions each year to ensure every project receives our complete attention. If you're planning a 2026 or 2027 wedding, now is the time to reach out.</p>
        <Button href="/contact" variant="primary">Start Your Inquiry</Button>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>