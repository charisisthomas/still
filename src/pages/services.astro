---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<Layout title="Services | Still">
  <Header />
  
  <main class="w-full bg-surface pt-[84px]">
    
    <!-- Hero Section -->
    <section class="max-w-[1440px] mx-auto px-6 md:px-12 pt-24 pb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="max-w-[800px] animate-on-scroll">
                <span class="block mb-6 font-label text-[11px] uppercase tracking-[0.28em] text-primary">
                    SERVICES & COMMISSIONS
                </span>
                <h1 class="font-headline text-5xl md:text-[60px] leading-[1.1] text-on-surface mb-8" style="text-wrap: balance;">
                    Digital Experiences for <br/> <span class="italic text-primary">the Modern Wedding</span>
                </h1>
                <div class="max-w-[600px]">
                    <p class="font-body text-lg md:text-[20px] leading-[1.7] text-secondary" style="text-wrap: pretty;">
                        We build bespoke digital infrastructure for high-end celebrations. From a single-page editorial announcement to a multi-day guest app with real-time flight tracking, every commission is built from a blank canvas. We do not use templates. We do not recycle code. We build for you.
                    </p>
                </div>
            </div>
            <div class="animate-on-scroll" style="transition-delay: 200ms;">
                <div class="aspect-[4/3] bg-surface-container-low rounded-sm overflow-hidden shadow-lg relative">
                    <img src="/images/couple-holding-hands.jpg" alt="Bespoke Digital Design" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000">
                    <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- The Commissions -->
    <section class="w-full bg-surface-container-low py-24 border-y border-outline-variant/10">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12">
            <div class="mb-16 animate-on-scroll">
                <span class="block mb-4 font-label text-[11px] uppercase tracking-[0.28em] text-primary">THE COMMISSIONS</span>
                <h2 class="font-headline text-3xl md:text-[40px] text-on-surface mb-6 leading-tight" style="text-wrap: balance;">Our Core Offerings</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- 01 Paperless Portal -->
                <div class="bg-surface border border-outline-variant/20 p-8 rounded-sm hover:shadow-md transition-all animate-on-scroll">
                    <div class="font-headline italic text-[48px] text-primary-fixed-dim mb-4">01</div>
                    <h3 class="font-headline text-[24px] text-on-surface mb-2">The Paperless Portal</h3>
                    <p class="font-body text-[14px] leading-[1.65] text-secondary mb-6">
                        A beautiful, single-page digital suite that replaces your entire printed stationery set. Digital invitations, RSVP collection, menus, and a live itinerary, all in one platform. Zero print.
                    </p>
                    <ul class="space-y-2 mb-6">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Digital invitation & RSVP logic</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Menu & seating guide integration</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Live digital itinerary</span>
                        </li>
                    </ul>
                    <div class="font-body text-[12px] text-secondary italic">
                        Best for: Couples prioritizing sustainability or looking for a sleek alternative to paper goods.
                    </div>
                </div>

                <!-- 02 Single Page Website -->
                <div class="bg-surface border border-outline-variant/20 p-8 rounded-sm hover:shadow-md transition-all animate-on-scroll" style="transition-delay: 100ms;">
                    <div class="font-headline italic text-[48px] text-primary-fixed-dim mb-4">02</div>
                    <h3 class="font-headline text-[24px] text-on-surface mb-2">Single Page Website</h3>
                    <p class="font-body text-[14px] leading-[1.65] text-secondary mb-6">
                        A continuous, scrolling editorial experience. Perfect for intimate weddings or modern couples who want to deliver all information in one cohesive narrative flow.
                    </p>
                    <ul class="space-y-2 mb-6">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Continuous editorial scroll</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Integrated schedule & venue info</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Basic travel & accommodation guide</span>
                        </li>
                    </ul>
                    <div class="font-body text-[12px] text-secondary italic">
                        Best for: Intimate or local weddings with straightforward logistics.
                    </div>
                </div>

                <!-- 03 Multi-Page Discovery -->
                <div class="bg-surface border border-outline-variant/20 p-8 rounded-sm hover:shadow-md transition-all animate-on-scroll" style="transition-delay: 200ms;">
                    <div class="font-headline italic text-[48px] text-primary-fixed-dim mb-4">03</div>
                    <h3 class="font-headline text-[24px] text-on-surface mb-2">Multi-Page Discovery</h3>
                    <p class="font-body text-[14px] leading-[1.65] text-secondary mb-6">
                        A deeply immersive website with dedicated pages for your story, complex travel guides, multi-event schedules, and segmented RSVP logic.
                    </p>
                    <ul class="space-y-2 mb-6">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Multi-page architecture</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Conditional RSVP logic</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Dedicated travel & accommodation hubs</span>
                        </li>
                    </ul>
                    <div class="font-body text-[12px] text-secondary italic">
                        Best for: Weekend-long domestic weddings requiring detailed guest guidance.
                    </div>
                    <a href="/portfolio/the-parisian-elope" class="block mt-4 font-label text-[11px] font-semibold text-primary hover:underline">→ See it in The Parisian Elope</a>
                </div>

                <!-- 04 Full Commission -->
                <div class="bg-primary-container border-l-4 border-primary p-8 rounded-sm shadow-md animate-on-scroll relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-br from-transparent to-primary-fixed-dim/10 pointer-events-none"></div>
                    <div class="relative z-10">
                        <div class="font-headline italic text-[48px] text-on-primary-container/80 mb-4">04</div>
                        <h3 class="font-headline text-[24px] text-on-primary-container mb-2">Website + App</h3>
                        <p class="font-body text-[14px] leading-[1.65] text-on-primary-container/80 mb-6">
                            Our flagship offering. The website builds anticipation and handles RSVPs; the mobile web app serves as a live concierge on the day with push notifications and photo sharing.
                        </p>
                        <ul class="space-y-2 mb-6">
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-on-primary-container text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                                <span class="font-body text-[13px] text-on-primary-container/90">Multi-page pre-wedding website</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-on-primary-container text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                                <span class="font-body text-[13px] text-on-primary-container/90">Mobile guest app (no download required)</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-on-primary-container text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                                <span class="font-body text-[13px] text-on-primary-container/90">Live itinerary & push notifications</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-on-primary-container text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                                <span class="font-body text-[13px] text-on-primary-container/90">Live guest photo sharing feed</span>
                            </li>
                        </ul>
                        <div class="font-body text-[12px] text-on-primary-container/70 italic">
                            Best for: Elevated weddings where the on-the-day guest experience is paramount.
                        </div>
                        <a href="/portfolio/the-amalfi-grandeur" class="block mt-4 font-label text-[11px] font-semibold text-on-primary-container hover:underline">→ See it in The Amalfi Grandeur</a>
                    </div>
                </div>

                <!-- 05 Destination Portal -->
                <div class="bg-surface border border-outline-variant/20 p-8 rounded-sm hover:shadow-md transition-all animate-on-scroll">
                    <div class="font-headline italic text-[48px] text-primary-fixed-dim mb-4">05</div>
                    <h3 class="font-headline text-[24px] text-on-surface mb-2">Destination Portal</h3>
                    <p class="font-body text-[14px] leading-[1.65] text-secondary mb-6">
                        Built specifically for international weddings. Features comprehensive travel hubs, real-time flight tracking, multilingual support, and curated local guides.
                    </p>
                    <ul class="space-y-2 mb-6">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Interactive international travel hub</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Real-time flight tracking integration</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Multilingual interface (up to 2 languages)</span>
                        </li>
                    </ul>
                    <div class="font-body text-[12px] text-secondary italic">
                        Best for: Couples bringing guests from multiple countries to a destination wedding.
                    </div>
                    <a href="/portfolio/the-cairo-tradition" class="block mt-4 font-label text-[11px] font-semibold text-primary hover:underline">→ See it in The Cairo Tradition</a>
                </div>

                <!-- 06 Custom Digital Concierge -->
                <div class="bg-surface border border-outline-variant/20 p-8 rounded-sm hover:shadow-md transition-all animate-on-scroll" style="transition-delay: 100ms;">
                    <div class="font-headline italic text-[48px] text-primary-fixed-dim mb-4">06</div>
                    <h3 class="font-headline text-[24px] text-on-surface mb-2">Custom Concierge</h3>
                    <p class="font-body text-[14px] leading-[1.65] text-secondary mb-6">
                        For weddings that go beyond a standard brief. We start from your specific requirements, scoping out custom features, complex logistics, and advanced guest personalisation logic.
                    </p>
                    <ul class="space-y-2 mb-6">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Custom feature design & engineering</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Advanced guest personalisation logic</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px] mt-0.5" style="font-variation-settings: 'FILL' 1;">check</span>
                            <span class="font-body text-[13px] text-on-surface-variant">Extended post-launch support</span>
                        </li>
                    </ul>
                    <div class="font-body text-[12px] text-secondary italic">
                        Best for: Estate weekends, multi-event commissions, or high-profile weddings.
                    </div>
                    <a href="/portfolio/the-santorini-serenity" class="block mt-4 font-label text-[11px] font-semibold text-primary hover:underline">→ See it in The Santorini Serenity</a>
                </div>
            </div>

            <!-- 07 Grand Scale -->
            <div class="mt-8 bg-surface border border-outline-variant/20 p-8 rounded-sm hover:shadow-md transition-all animate-on-scroll">
                <div class="flex flex-col md:flex-row gap-8 items-start md:items-center justify-between">
                    <div>
                        <div class="font-headline italic text-[48px] text-primary-fixed-dim mb-2">07</div>
                        <h3 class="font-headline text-[24px] text-on-surface mb-2">Grand Scale Commission</h3>
                        <p class="font-body text-[14px] leading-[1.65] text-secondary max-w-2xl">
                            For multi-event celebrations and commissions that don't fit a standard brief. We begin with a dedicated scoping session and build the brief from scratch around your specific requirements. Priced individually on inquiry.
                        </p>
                    </div>
                    <div class="flex-shrink-0">
                        <Button href="/contact" variant="primary" class="shadow-sm">Book a Discovery Call</Button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Comparison Matrix -->
    <section class="w-full bg-surface py-24 border-b border-outline-variant/10">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12 animate-on-scroll">
            <span class="block mb-4 font-label text-[11px] uppercase tracking-[0.28em] text-primary text-center">NOT SURE WHICH ONE IS RIGHT FOR YOU?</span>
            <h2 class="font-headline text-3xl md:text-[40px] text-on-surface mb-6 text-center">Find Your Commission</h2>
            <p class="font-body text-[15px] text-secondary text-center max-w-2xl mx-auto mb-16">
                The table below shows what's included in each tier. Every commission includes bespoke design, password protection, mobile-optimised build, and a post-event archive — regardless of tier. <br/>
                <a href="/pricing" class="text-primary hover:underline mt-2 inline-block">See everything that's always included and view pricing ranges →</a>
            </p>

            <div class="overflow-x-auto border border-outline-variant/20 rounded-sm shadow-sm bg-surface">
                <table class="w-full text-left border-collapse min-w-[900px]">
                    <thead>
                        <tr class="bg-surface-container-low border-b border-outline-variant/20">
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-secondary">Feature</th>
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-secondary text-center">Paperless</th>
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-secondary text-center">Single Pg</th>
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-secondary text-center">Multi-Pg</th>
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-primary font-bold text-center bg-primary-container/10">Full Comm.</th>
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-secondary text-center">Destination</th>
                            <th class="p-6 font-label text-[11px] uppercase tracking-[0.2em] text-secondary text-center">Concierge</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/10">
                        <tr class="hover:bg-surface-container-lowest transition-colors">
                            <td class="p-6 font-body text-[14px] text-on-surface font-medium">Digital invitation & RSVP</td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center bg-primary-container/5"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                        </tr>
                        <tr class="hover:bg-surface-container-lowest transition-colors">
                            <td class="p-6 font-body text-[14px] text-on-surface font-medium">Multi-page editorial website</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center bg-primary-container/5"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                        </tr>
                        <tr class="hover:bg-surface-container-lowest transition-colors">
                            <td class="p-6 font-body text-[14px] text-on-surface font-medium">RSVP with conditional logic</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center bg-primary-container/5"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                        </tr>
                        <tr class="hover:bg-surface-container-lowest transition-colors">
                            <td class="p-6 font-body text-[14px] text-on-surface font-medium">Guest mobile app (no download)</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
                            <td class="p-6 text-center bg-primary-container/5"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                            <td class="p-6 text-center"><span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">check_circle</span></td>
                        </tr>
                        <tr class="hover:bg-surface-container-lowest transition-colors">
                            <td class="p-6 font-body text-[14px] text-on-surface font-medium">Live itinerary & push notifications</td>
                            <td class="p-6 text-center text-outline-variant text-[14px]">—</td>
