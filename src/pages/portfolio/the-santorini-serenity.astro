---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import PortfolioNav from '../../components/portfolio/PortfolioNav.astro';
---

<Layout title="The Santorini Serenity | Case Study | Still">
  <Header />
  
  <main class="pt-24 min-h-screen">
    <!-- Hero Section -->
    <section class="relative min-h-[80vh] md:min-h-screen overflow-hidden flex items-center justify-center">
    <div class="absolute inset-0 z-0">
    <img class="w-full h-full object-cover grayscale-[20%]" data-alt="Cinematic wide shot of a Chinese couple, Mei and Kenji, standing on a white Santorini balcony at sunset with blue domes in the distance." src="/images/santorini-hero.png"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-aegean/30 to-aegean/80"></div>
    </div>
    <div class="relative z-10 text-center px-6 animate-on-scroll mt-20">
    <span class="font-label text-sm text-on-primary uppercase tracking-[0.3em] mb-4 block opacity-90">Destination Case Study</span>
    <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl text-white drop-shadow-2xl max-w-4xl mx-auto leading-tight break-words">
                        The Santorini Serenity: <span class="font-display italic">Mei &amp; Kenji</span>
    </h1>
    </div>
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
    <span class="material-symbols-outlined text-white text-3xl">keyboard_double_arrow_down</span>
    </div>
    </section>
    <!-- The Brief Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-16 items-start">
      <div class="md:col-span-4 sticky top-32 animate-on-scroll">
        <h2 class="text-3xl font-headline text-primary border-l-2 border-primary-container pl-6 py-2">The Brief</h2>
        <div class="mt-8 flex flex-col gap-4">
          <div>
            <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Location</span>
            <span class="text-sm font-medium">Oia, Santorini</span>
          </div>
          <div>
            <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Scope</span>
            <span class="text-sm font-medium">Offline-First Guest Experience</span>
          </div>
          <div>
            <span class="block text-[10px] uppercase tracking-widest text-secondary mb-1">Guests</span>
            <span class="text-sm font-medium">Destination Gathering</span>
          </div>
        </div>
      </div>
      <div class="md:col-span-8 animate-on-scroll" style="transition-delay: 200ms;">
        <p class="text-2xl md:text-3xl font-headline leading-relaxed text-on-surface-variant">
          "We wanted our guests to feel the salt in the air before they even boarded their flights."
        </p>
        <p class="mt-12 text-lg text-secondary leading-loose max-w-2xl font-body">
          Still transformed a minimalist aesthetic into a digital platform that managed every detail while feeling like a luxury editorial piece, countering low-connectivity environments on the island.
        </p>
      </div>
    </section>

    
    <!-- The Vision -->
    <section class="py-24 md:py-32 bg-surface">
    <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    <div class="md:col-span-5 animate-on-scroll">
    <span class="text-aegean font-bold tracking-widest text-xs uppercase mb-6 block">The Vision</span>
    <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-8 leading-tight">A minimalist digital gateway to the Aegean.</h2>
    </div>
    <div class="md:col-span-6 md:col-start-7 animate-on-scroll" style="transition-delay: 200ms;">
    <p class="text-on-surface-variant text-lg leading-relaxed font-light italic border-l-2 border-primary-fixed-dim pl-8">
                                "We wanted our guests to feel the salt in the air before they even boarded their flights. Still transformed our minimalist aesthetic into a digital platform that managed every detail while feeling like a luxury editorial piece."
                            </p>
    <div class="mt-8 flex gap-4 text-secondary text-sm">
    <span class="flex items-center gap-2"><span class="material-symbols-outlined text-xs" data-weight="fill">location_on</span> Oia, Santorini</span>
    <span class="flex items-center gap-2"><span class="material-symbols-outlined text-xs" data-weight="fill">calendar_today</span> September 2024</span>
    </div>
    </div>
    </div>
    </div>
    </section>
    
    <!-- Digital Innovations (Bento Style) -->
    <section class="py-24 bg-surface-container-low overflow-hidden">
    <div class="container mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
    <h2 class="font-headline text-4xl mb-4 text-primary">Digital Innovations</h2>
    <p class="text-secondary max-w-xl mx-auto">Seamless experiences crafted for the discerning traveler.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- App Screen: Newsletter -->
    <div class="bg-surface-container-lowest p-8 flex flex-col items-center justify-center transform hover:-translate-y-2 transition-transform duration-500 animate-on-scroll">
    <div class="w-64 h-[450px] bg-white rounded-[3rem] border-[8px] border-on-surface shadow-2xl relative overflow-hidden flex flex-col">
    <div class="p-6 pt-12 flex-grow">
    <div class="font-headline text-aegean italic text-xl mb-4">The Aegean Journal</div>
    <div class="h-32 w-full bg-surface-container rounded-sm mb-4">
    <img class="w-full h-full object-cover" data-alt="Abstract blue water texture from the Santorini caldera with golden sunlight reflecting on surface." src="/images/santorini-landscape.jpg"/>
    </div>
    <h4 class="font-bold text-xs uppercase tracking-tighter mb-2 text-on-surface">Issue No. 4: Island Flora</h4>
    <p class="text-[10px] text-secondary leading-relaxed">Discover the native blossoms of Santorini that inspired our floral arrangements...</p>
    </div>
    <div class="p-6 border-t border-surface-variant text-center">
    <span class="text-[10px] font-bold text-aegean">READ NEWSLETTER</span>
    </div>
    </div>
    <h3 class="mt-8 font-headline text-xl text-aegean">The Newsletter</h3>
    <p class="text-xs text-secondary mt-2">Curated bi-weekly travel guides.</p>
    </div>
    <!-- App Screen: RSVP -->
    <div class="bg-aegean p-8 flex flex-col items-center justify-center transform md:translate-y-12 transition-transform duration-500 animate-on-scroll" style="transition-delay: 150ms;">
    <div class="w-64 h-[450px] bg-surface rounded-[3rem] border-[8px] border-surface-container shadow-2xl relative overflow-hidden flex flex-col group">
    <div class="p-6 pt-12 text-center">
    <span class="material-symbols-outlined text-primary mb-4" style="font-variation-settings: 'FILL' 1;">favorite</span>
    <h4 class="font-headline text-xl mb-6 text-on-surface">Will You Join Us?</h4>
    <div class="space-y-3">
    <button class="w-full p-3 border border-aegean bg-aegean/5 hover:bg-aegean/10 transition-colors text-xs text-left flex justify-between items-center text-on-surface rounded-sm cursor-pointer">
    <span>Accept with Joy</span>
    <div class="w-2 h-2 rounded-full bg-aegean"></div>
    </button>
    <button class="w-full p-3 border border-outline-variant/30 hover:border-outline-variant/60 transition-colors text-xs text-left flex justify-between items-center opacity-60 text-on-surface rounded-sm cursor-pointer">
    <span>Decline with Regret</span>
    </button>
    </div>
    <div class="mt-8">
    <label class="text-[8px] block text-left mb-1 uppercase tracking-widest text-on-surface">Dietary Preference</label>
    <div class="h-8 border-b border-aegean/20 text-xs text-left text-on-surface-variant flex items-end pb-1">None</div>
    </div>
    </div>
    <button class="absolute bottom-10 left-1/2 -translate-x-1/2 w-4/5 bg-aegean text-white py-3 rounded-full text-xs font-bold tracking-widest hover:bg-primary transition-colors cursor-pointer shadow-md">SUBMIT</button>
    </div>
    <h3 class="mt-8 font-headline text-xl text-white">Frictionless RSVP</h3>
    <p class="text-xs text-on-primary-container/80 mt-2 text-white/80">Intelligent dietary &amp; stay management.</p>
    </div>
    <!-- App Screen: Photo Stream -->
    <div class="bg-surface-container-lowest p-8 flex flex-col items-center justify-center transform hover:-translate-y-2 transition-transform duration-500 animate-on-scroll" style="transition-delay: 300ms;">
    <div class="w-64 h-[450px] bg-white rounded-[3rem] border-[8px] border-on-surface shadow-2xl relative overflow-hidden flex flex-col">
    <div class="p-6 pt-12 flex-grow">
    <div class="flex justify-between items-center mb-4">
    <span class="font-headline italic text-xs text-on-surface">Live Stream</span>
    <span class="flex items-center gap-1 text-[8px] text-on-surface"><span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span> LIVE</span>
    </div>
    <div class="grid grid-cols-2 gap-2">
    <div class="h-20 bg-surface-container">
    <img class="w-full h-full object-cover" data-alt="Polaroid style photo of wedding appetizers on a stone table." src="/images/santorini-cake.jpg"/>
    </div>
    <div class="h-20 bg-surface-container">
    <img class="w-full h-full object-cover" data-alt="Polaroid style photo of the groom Kenji adjusting his gold watch." src="/images/santorini-sightseen.jpg"/>
    </div>
    <div class="h-32 col-span-2 bg-surface-container">
    <img class="w-full h-full object-cover" data-alt="Close up of white rose and gold wedding decorations." src="/images/woman-hands-ring-closeup-jonathanborba.jpg"/>
    </div>
    </div>
    </div>
    <div class="p-4 bg-aegean/5 text-center">
    <span class="material-symbols-outlined text-aegean">photo_camera</span>
    </div>
    </div>
    <h3 class="mt-8 font-headline text-xl text-aegean">Real-time Memories</h3>
    <p class="text-xs text-secondary mt-2">Instant photo sharing for all guests.</p>
    </div>
    </div>
    </div>
    </section>
    
    <!-- The Interactive Map -->
    <section class="py-24 bg-surface">
    <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="space-y-8 animate-on-scroll">
    <span class="text-aegean font-bold tracking-widest text-xs uppercase block">Guest Experience</span>
    <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl text-primary">The Treasure Hunt of Oia</h2>
    <p class="text-on-surface-variant text-lg leading-relaxed">
                                We gamified the arrival experience. Guests received an illustrated interactive map that led them through the winding paths of Santorini. Each 'pin' was a curated memory or a local secret—from the best gelato in town to the specific viewpoint where Kenji proposed.
                            </p>
    <div class="space-y-6 mt-8">
    <div class="flex items-start gap-4">
    <span class="text-aegean font-headline italic text-2xl">01</span>
    <div>
    <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface mb-1">Secret Viewpoints</h4>
    <p class="text-sm text-secondary">Exclusive access to private balconies for photography.</p>
    </div>
    </div>
    <div class="flex items-start gap-4">
    <span class="text-aegean font-headline italic text-2xl">02</span>
    <div>
    <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface mb-1">Local Artisans</h4>
    <p class="text-sm text-secondary">Hidden workshops where guests picked up custom linens.</p>
    </div>
    </div>
    </div>
    </div>
    <div class="w-full h-[600px] relative animate-on-scroll" style="transition-delay: 200ms;">
    <div class="absolute inset-0 bg-surface-container-low p-2">
    <div class="w-full h-full relative overflow-hidden bg-white/50 backdrop-blur-sm border border-outline-variant/20">
    <img class="w-full h-full object-cover opacity-60" data-alt="Stylized top-down view of Santorini cliffside architecture with hand-drawn gold line map overlays and marker pins." src="/images/santorini-map.jpg"/>
    <div class="absolute top-1/4 left-1/3 p-4 bg-white shadow-xl flex items-center gap-3">
    <span class="material-symbols-outlined text-aegean">place</span>
    <span class="text-[10px] font-bold uppercase tracking-tighter text-on-surface">Proposal Point</span>
    </div>
    <div class="absolute bottom-1/3 right-1/4 p-4 bg-white shadow-xl flex items-center gap-3">
    <span class="material-symbols-outlined text-aegean">restaurant</span>
    <span class="text-[10px] font-bold uppercase tracking-tighter text-on-surface">Welcome Dinner</span>
    </div>
    </div>
    </div>
    <div class="absolute -bottom-6 -left-6 bg-aegean text-white p-8 shadow-xl max-w-xs">
    <div class="font-headline italic text-3xl">Interactive Map</div>
    <p class="text-xs mt-3 opacity-90 font-medium">BUILT WITH CUSTOM GEO-LOCALIZATION</p>
    </div>
    </div>
    </div>
    </div>
    </section>
    
    <!-- The Gallery -->
    <section class="py-24 bg-surface">
    <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <div class="animate-on-scroll self-center">
    <img class="w-full h-auto grayscale transition-all hover:grayscale-0 duration-700 rounded-sm shadow-sm" data-alt="Detailed close up of a minimalist white wedding cake with a single sprig of gold-leaf olive branch." src="/images/santorini-hero.png"/>
    </div>
    <div class="animate-on-scroll self-center" style="transition-delay: 100ms;">
    <img class="w-full h-auto rounded-sm shadow-sm" data-alt="Mei in her elegant wedding dress walking through a narrow white-walled Santorini alley." src="/images/santorini-landscape.jpg"/>
    </div>
    <div class="animate-on-scroll self-center" style="transition-delay: 200ms;">
    <div class="p-12 bg-surface-container flex flex-col justify-center items-center text-center rounded-sm h-full min-h-[300px]">
    <span class="material-symbols-outlined text-4xl text-aegean mb-4">auto_awesome</span>
    <h3 class="font-headline text-2xl italic text-on-surface">The Details</h3>
    <p class="text-xs text-secondary mt-2">Every pixel planned to perfection.</p>
    </div>
    </div>
    <div class="animate-on-scroll self-center">
    <img class="w-full h-auto rounded-sm shadow-sm" data-alt="Kenji looking out over the Aegean sea at sunset, silhouetted against the orange and pink sky." src="/images/santorini-cake.jpg"/>
    </div>
    <div class="animate-on-scroll self-center" style="transition-delay: 100ms;">
    <img class="w-full h-auto rounded-sm shadow-sm" data-alt="Long exposure shot of the wedding dinner table set up outdoors on a terrace at night under fairy lights." src="/images/santorini-sightseen.jpg"/>
    </div>
    <div class="animate-on-scroll self-center" style="transition-delay: 200ms;">
    <img class="w-full h-auto grayscale transition-all hover:grayscale-0 duration-700 rounded-sm shadow-sm" data-alt="The couple's hands joined together showing simple gold wedding bands." src="/images/woman-hands-ring-closeup-jonathanborba.jpg"/>
    </div>
    </div>
    </div>
    </section>
    
    <!-- Testimonial Section -->
    <section class="py-32 bg-aegean text-white text-center">
    <div class="container mx-auto px-6 animate-on-scroll">
    <span class="material-symbols-outlined text-5xl mb-12 opacity-30">format_quote</span>
    <blockquote class="font-headline text-3xl md:text-5xl max-w-4xl mx-auto leading-tight italic text-white">
                        "The team at Still didn’t just build us a website; they built us a digital legacy asset. It was the heart of our wedding experience from the first email to the last photo upload."
                    </blockquote>
    <cite class="mt-12 block not-italic font-bold tracking-[0.2em] uppercase text-sm text-white">— Mei &amp; Kenji</cite>
    </div>
    </section>
    
    <!-- CTA Section -->
    <section class="py-24 bg-surface text-center">
    <div class="container mx-auto px-6 animate-on-scroll">
    <div class="max-w-2xl mx-auto py-16 border-y border-outline-variant/20">
    <h2 class="font-headline text-4xl mb-8 text-primary">Ready to Build Your Wedding Site?</h2>
    <p class="text-on-surface-variant mb-12">Let’s collaborate to create a digital experience that honors your story.</p>
    <a href="/contact" class="inline-block bg-primary text-on-primary px-12 py-4 uppercase tracking-[0.3em] text-sm font-bold transition-all hover:scale-105 active:opacity-70">
                            Contact Us
                        </a>
    </div>
      </div>
    </section>
    
    <PortfolioNav currentSlug="the-santorini-serenity" />
  </main>
  
  <Footer />
</Layout>