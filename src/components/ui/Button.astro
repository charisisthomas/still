---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'tertiary';
  class?: string;
  [key: string]: any;
}
const { href, variant = 'primary', class: className = '', ...rest } = Astro.props;

const baseClass = "inline-flex items-center justify-center transition-all duration-300 font-medium";
const variants = {
  primary: "bg-primary text-on-primary rounded-sm px-8 py-4 hover:bg-primary-dim tracking-wide text-sm disabled:opacity-50 disabled:cursor-not-allowed",
  secondary: "bg-transparent text-on-surface border border-outline-variant/20 rounded-sm px-8 py-4 hover:bg-surface-container-low tracking-wide text-sm disabled:opacity-50 disabled:cursor-not-allowed",
  tertiary: "font-display italic text-on-surface border-b border-primary-fixed-dim hover:text-primary pb-1 disabled:opacity-50"
};
---

{href ? (
  <a href={href} class={`${baseClass} ${variants[variant]} ${className}`} {...rest}>
    <slot />
  </a>
) : (
  <button class={`${baseClass} ${variants[variant]} ${className}`} {...rest}>
    <slot />
  </button>
)}
