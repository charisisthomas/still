---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-container-low pt-24 pb-12 mt-32">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="col-span-1 md:col-span-1">
      <a href="/" class="text-4xl font-display text-primary block mb-6">Still</a>
      <p class="text-on-surface-variant text-sm max-w-xs leading-relaxed">
        Bespoke digital experiences for the world's most intentional weddings.
      </p>
    </div>
    
    <div class="col-span-1 flex flex-col gap-4 text-sm tracking-wide">
      <h4 class="font-display text-primary text-xl mb-2">Work</h4>
      <a href="/portfolio" class="hover:text-primary transition-colors">Portfolio</a>
      <a href="/services" class="hover:text-primary transition-colors">Services</a>
      <a href="/investment" class="hover:text-primary transition-colors">Investment</a>
    </div>

    <div class="col-span-1 flex flex-col gap-4 text-sm tracking-wide">
      <h4 class="font-display text-primary text-xl mb-2">Studio</h4>
      <a href="/process" class="hover:text-primary transition-colors">The Process</a>
      <a href="/about" class="hover:text-primary transition-colors">About</a>
      <a href="/faq" class="hover:text-primary transition-colors">FAQ</a>
    </div>

    <div class="col-span-1 flex flex-col gap-4 text-sm tracking-wide">
      <h4 class="font-display text-primary text-xl mb-2">Legal</h4>
      <a href="/privacy" class="hover:text-primary transition-colors">Privacy Policy</a>
      <a href="/terms" class="hover:text-primary transition-colors">Terms of Service</a>
      <div class="mt-6 flex gap-6">
        <a href="#" class="text-on-surface hover:text-primary transition-colors">Instagram</a>
        <a href="#" class="text-on-surface hover:text-primary transition-colors">Pinterest</a>
      </div>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto px-6 mt-20 pt-8 border-t border-outline-variant/20 flex flex-col md:flex-row justify-between items-center text-xs tracking-wider text-on-surface-variant uppercase">
    <p>&copy; {currentYear} Still. All Rights Reserved.</p>
  </div>
</footer>
