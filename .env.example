# Resend.com API Configuration
# Get your API key from https://resend.com/dashboard/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Verified sender email address. 
# Note: For free/sandbox Resend accounts, this MUST be onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# Recipient address where wedding inquiries should be delivered
RESEND_TO_EMAIL=hello@still.com
